[Unit]
Description=Autosync Daemon - Continuous rsync-based synchronization
After=network.target

[Service]
Type=simple
Environment=HOME=%h
WorkingDirectory=##WORKING_DIR##
ExecStart=##WORKING_DIR##/autosync.sh
Restart=always
RestartSec=30
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
